{
  "scripts": {
    "wa:copy": "cp -r node_modules/@awesome.me/webawesome/dist-cdn/ assets/webawesome/",
    "fonts:copy": "cp node_modules/@fontsource/roboto-mono/files/roboto-mono-latin-400-normal.woff2 assets/fonts/roboto-mono/RobotoMono-Regular.woff2 && cp node_modules/@fontsource/roboto-mono/files/roboto-mono-latin-500-normal.woff2 assets/fonts/roboto-mono/RobotoMono-Medium.woff2",
    "build": "JEKYLL_ENV=production bundle exec jekyll build && npx purgecss --config purgecss.config.js --output _site/css"
  },
  "dependencies": {
    "@awesome.me/webawesome": "^3",
    "purgecss": "^7.0.2"
  },
  "devDependencies": {
    "@fontsource/roboto-mono": "^5.2.9"
  }
}
